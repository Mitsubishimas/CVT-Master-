<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1C1C1E">
    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CVT Master"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>
    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mitsubishi Edition"
        android:textSize="14sp"
        android:textColor="#FF6200EE"/>
    
    <!-- Статус подключения -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#2C2C2E"
        android:padding="12dp"
        android:layout_marginTop="16dp">
        
        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="#FF3B30"/>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Не подключено"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
    
    <!-- Панель мониторинга -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#2C2C2E"
            android:padding="12dp"
            android:layout_marginEnd="8dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Температура CVT"
                android:textColor="#8E8E93"
                android:textSize="12sp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°C"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#2C2C2E"
            android:padding="12dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Деградация масла"
                android:textColor="#8E8E93"
                android:textSize="12sp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
    
    <!-- Кнопки действий -->
    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сканировать ошибки"
        android:layout_marginTop="16dp"
        android:backgroundTint="#FF6200EE"/>
    
    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сбросить счетчик деградации"
        android:layout_marginTop="8dp"
        android:backgroundTint="#FF3B30"/>
    
    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Обучение CVT"
        android:layout_marginTop="8dp"
        android:backgroundTint="#34C759"/>
</LinearLayout>
